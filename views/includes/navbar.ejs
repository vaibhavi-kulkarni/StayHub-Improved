<style>
  .btn-search {
    background-color:  #FF5A5F;
    color: white;
    border-radius: 25px;
    padding : 0 1rem 0 1rem;
  }
  .btn-search:hover {
    background-color:  #FF5A5F;
    color: white;
  }
  .btn-search i{
    display :inline;
    margin :0.5rem;
  }
  .inp-search {
    border-radius: 25px;
    padding : 0.5rem 3rem 0.5rem 3rem;
    font-size:1rem; 
  }
  #icon {
    color: #FF5A5F;
  }
</style>
<nav class="navbar navbar-expand-md bg-body-tertiary sticky-top border-bottom">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings"><i class="fa-solid fa-umbrella-beach" id="icon"></i></a>
      <button class="navbar-toggler" 
        type="button" 
        data-bs-toggle="collapse" 
        data-bs-target="#navbarNavAltMarkup" 
        aria-controls="navbarNavAltMarkup" 
        aria-expanded="false" 
        aria-label="Toggle navigation" 
      >
      <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings"><b>Explore</b></a>
        </div>
        <div class="navbar-nav ms-auto">
          <form class="d-flex">
            <input class="form-control mr-sm-2 me-2 inp-search" type="search" placeholder="Search destinations" aria-label="Search">
            <button class="btn btn-search my-2 my-sm-0" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search&nbsp;&nbsp;&nbsp;&nbsp; </button>
          </form>
        </div>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/listings/new"><b>Add new listings</b></a>
          <% if (!currUser) { %>
              <a class="nav-link" aria-current="page" href="/signup"><b>Sign Up</b></a>
              <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } %>
          
          <% if (currUser) { %>
              <a class="nav-link" href="/logout">Log Out</a>
          <% } %>
      </div>      
      </div>
    </div>
</nav>